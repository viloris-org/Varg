script PlayerController {
    @export var speed: Float = 6.0
    @export var jumpForce: Float = 8.0

    var jumpsLeft: Int = 1

    func start() {
        log("player ready")
    }

    func update(_ dt: Float) {
        entity.translate(Vec3(Input.actionValue("MoveX") * speed * dt, 0, Input.actionValue("MoveY") * speed * dt))

        if Input.pressed("jump") {
            entity.position.y += jumpForce * dt
            jumpsLeft -= 1
        }
    }
}
